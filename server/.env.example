# ============================================================
# Community Micro-Inventory System V2 — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# -- Server --
PORT=3000
NODE_ENV=development

# -- JWT --
JWT_SECRET=change_this_to_a_long_random_secret_string_minimum_32_chars
JWT_EXPIRES_IN=7d

# -- Database --
DB_PATH=./data/inventory.db

# -- CORS --
CLIENT_ORIGIN=http://localhost:3000

# -- Low Stock Threshold --
LOW_STOCK_THRESHOLD=5

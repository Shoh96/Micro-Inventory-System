# ============================================================
# Community Micro-Inventory System — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# -- Server --
PORT=3000

# -- JWT --
# Use a long, random, unguessable string in production.
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# -- Database --
# Path to the SQLite database file (relative to server/)
DB_PATH=./data/inventory.db

# -- CORS --
# Front-end origin allowed to call this API.
# In production set to your actual frontend URL.
CLIENT_ORIGIN=http://localhost:5500
